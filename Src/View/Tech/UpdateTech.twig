{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Modification téchnicien{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-shield-check me-2"></i>Modification téchniciens
                    </h1>
                    <p class="text-muted small mb-0">Veuillez fournir toutes les informations ci-dessous</p>
                </div>

                {# Formulaire #}
                <form method="post">
                    {# Partie Nom #}
                    <div class="row mb-3 align-items-center">
                        <label for="Nom" class="col-sm-3 col-form-label fw-medium">Nom</label>
                        <div class="col-sm-9">
                            <input class="form-control" type="text" name="Nom" id="Nom" value="{{ TechEntity.getNom() }}" required>
                        </div>
                    </div>

                    {# Partie prénom #}
                    <div class="row mb-3 align-items-center">
                        <label for="Pren" class="col-sm-3 col-form-label fw-medium">Prenom</label>
                        <div class="col-sm-9">
                            <input class="form-control" type="text" name="Pren" id="Pren" value="{{ TechEntity.getPrenom() }}" required>
                        </div>
                    </div>

                    {# Partie e-mail#}
                    <div class="row mb-3 align-items-center">
                        <label for="Email" class="col-sm-3 col-form-label fw-medium">Email</label>
                        <div class="col-sm-9">
                            <input class="form-control" name="Email" id="Email" value="{{ TechEntity.getEmail() }}" required>
                        </div>
                    </div>

                    {# Partie actif #}
                    <div class="row mb-4 align-items-center">
                        <label class="col-sm-3 col-form-label fw-medium">Actif</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="Actif" id="Actif" value="1" {{ TechEntity.getActif() ? 'checked' : '' }}>
                            </div>
                        </div>
                    </div>

                    {# Listins des fonctions #}
                    <div class="border rounded-3 overflow-hidden">
                        <table class="table table-hover mb-0">
                            <thead>
                            <tr>
                                <th>Fonction</th>
                                <th></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for fonction in TabFonction %}
                                <tr>
                                    <td>
                                        <div class="form-check mb-0">
                                            <input class="form-check-input" type="checkbox" name="fonctions[]" value="{{ fonction.getPk() }}" id="f_{{ fonction.getPk() }}"
                                                    {% set isChecked = false %}
                                                    {% for userFonction in TechEntity.getFonctions() %}
                                                        {% if userFonction.getPk() == fonction.getPk() %}
                                                            {% set isChecked = true %}
                                                        {% endif %}
                                                    {% endfor %}
                                                    {{ isChecked ? 'checked' : '' }}
                                            >
                                            <label class="form-check-label" for="f_{{ fonction.getPk() }}">
                                                {{ fonction.getDescr() }}
                                            </label>
                                        </div>
                                    </td>
                                    <td></td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="2" class="text-center text-muted">Aucune fonction disponible</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {# Partie action formulaire#}
                    <div class="row-cols-sm-5 p-4">
                        <div class="col-12 text-center d-flex justify-content-center gap-2">
                            <button class="btn btn-outline-success px-4" type="submit">Envoyer</button>
                            <a class="btn btn-outline-warning px-4" href="getTech">Retour</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

{% endblock %}