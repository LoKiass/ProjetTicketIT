{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Liste fonction{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 800px; border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-people me-2"></i>Liste des fonctions
                    </h1>
                    <p class="text-muted small mb-0">Liste de toutes les fonctions enregistrés</p>
                </div>

                {% if errorMessage is defined and errorMessage is not null%}
                    <div class="alert alert-danger">{{ errorMessage }}</div>
                {% endif %}

                {% if TabFonction is not null %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th class="text-uppercase small text-muted fw-semibold">Description</th>
                                <th class="text-uppercase small text-muted fw-semibold">Niveau</th>
                                <th class="text-uppercase small text-muted fw-semibold">Téchniciens attribué</th>
                                <th class="text-uppercase small text-muted fw-semibold">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for fonctions in TabFonction %}
                                <tr>
                                    <td class="fw-semibold">{{ fonctions.getDescr }}</td>
                                    <td>{{ fonctions.getNiveau }}</td>
                                    <td>//</td>
                                    <td>
                                        <a href="updateFonction?Pk={{ fonctions.getPk }}" class="btn btn-sm btn-outline-primary me-1">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                        <a href="getFonction?Pk={{ fonctions.getPk }}" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-info-circle"></i> Infos
                                        </a>
                                        <a href="deleteFonction?Pk={{ fonctions.getPk }}" class="btn btn-sm btn-outline-danger">Suppresions</a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% if successUpdate is defined and successUpdate %}
                        <p class="text-success text-center bg-light p-1">Fonction modifier aves succès</p>
                    {% endif %}
                    {% if successDelete is defined and successDelete %}
                        <p class="text-success text-center bg-light p-1">Fonction supprimer aves succès</p>
                    {% endif %}

                {% endif %}

            </div>
        </div>
    </div>
{% endblock %}