{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Liste technicien{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}

{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 800px; border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-people me-2"></i>Liste des Job
                    </h1>
                    <p class="text-muted small mb-0">Liste de tous les jobs enregistrés</p>
                </div>

                {% if errorMessage is defined %}
                    <div class="alert alert-danger">{{ errorMessage }}</div>
                {% endif %}


                {% if TabJob is not null %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th class="text-uppercase small text-muted fw-semibold">Projet associer</th>
                                <th class="text-uppercase small text-muted fw-semibold">Titre</th>
                                <th class="text-uppercase small text-muted fw-semibold">Description</th>
                                <th class="text-uppercase small text-muted fw-semibold">Status</th>
                                <th class="text-uppercase small text-muted fw-semibold">Priorité</th>
                                <th class="text-uppercase small text-muted fw-semibold">Date de début</th>
                                <th class="text-uppercase small text-muted fw-semibold">Date de cloture</th>
                                <th class="text-uppercase small text-muted fw-semibold">Date d'échéance</th>
                                <th class="text-uppercase small text-muted fw-semibold">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for job in TabJob %}
                                <tr>
                                    <td class="fw-semibold">{{ job.getFk_project() }}</td>
                                    <td class="fw-semibold">{{ job.getTitre() }}</td>
                                    <td class="fw-semibold">{{ job.getDscr()}}</td>
                                    <td>
                                        {% if job.getStatus %}
                                            <span class="badge bg-success">Actif</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Inactif</span>
                                        {% endif %}
                                    </td>
                                    <td class="fw-semibold">{{ job.getPrior() }}</td>
                                    <td class="fw-semibold">{{ job.getDstart() }}</td>
                                    <td class="fw-semibold">{{ job.getDclot() }}</td>
                                    <td class="fw-semibold">{{ job.getDech() }}</td>
                                    <td>
                                        <a href="updateJob?Pk={{ job.getPk() }}" class="btn btn-sm btn-outline-primary me-1">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                        <a href="getTech?Pk={{ job.getPk() }}" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-info-circle"></i> Infos
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% if success is defined and success %}
                        <p class="text-success text-center bg-light p-1">Techniciens modifier aves succès</p>
                    {% endif %}
                {% endif %}

            </div>
        </div>
    </div>
{% endblock %}