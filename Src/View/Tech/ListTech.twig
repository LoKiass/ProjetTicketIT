{% extends 'baseTemplate.twig' %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block headerTitre %}<h1>Listing des téchniciens</h1>{% endblock %}
{% block content %}
    <table>
        <tr>
            <th>Nom</th>
            <th>Prenom</th>
            <th>Email</th>
            <th>Actif</th>
        </tr>
        {% if TabTech is not null %}
            {% for tech in TabTech %}
            <tr>
                    <td>{{ tech.getNom }}</td>
                    <td>{{ tech.getPrenom }}</td>
                    <td>{{ tech.getEmail }}</td>
                    <td>{{ tech.getActif ? 'Actif' : 'Inactif' }}</td>
                    <td><a href="updateTech?Pk={{ tech.getPk }}">Modification</a></td>
                    <td><a href="getTech?Pk={{ tech.getPk }}">Information</a></td>
            </tr>
            {% endfor %}
        {% if errorMessage is defined %}
            {{ errorMessage }}
            {% endif  %}
        {% endif %}
    </table>
{% endblock %}