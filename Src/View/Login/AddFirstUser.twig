{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Login{% endblock %}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center align-items-center bg-light">
        <div class="card shadow-sm border-0 w-100" style="max-width: 450px; border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4 text-center">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-person-lock me-2"></i>Première connexion
                    </h1>
                    <p class="text-muted small mb-0">Veuillez crée le compte administrateur</p>
                </div>

                <form method="post">
                    {# Partie nom d'utilisateur #}
                    <div class="mb-3">
                        <label for="Login" class="form-label fw-medium">Nom d'utilisateur</label>
                        <input type="text" name="Login" id="Login" class="form-control" value="admin" readonly required>
                    </div>

                    {# Partie status #}
                    <div class="mb-3">
                        <label for="Statut" class="form-label fw-medium">Status</label>
                        <input type="text" name="Statut" id="Statut" class="form-control" value="admin" readonly required>
                    </div>

                    {# Partie mot de passe #}
                    <div class="mb-4">
                        <label for="Pswd" class="form-label fw-medium">Mot de passe</label>
                        <input type="password" name="Pswd" id="Pswd" class="form-control">
                    </div>
                    {# Partie mot de passe #}
                    <div class="mb-4">
                        <label for="PswdConfirm" class="form-label fw-medium">Re-introduire le mots de passe</label>
                        <input type="password" name="PswdConfirm" id="PswdConfirm" class="form-control">
                    </div>

                    {# Partie action formulaire #}
                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark">Connexion</button>
                    </div>
                </form>
                {# Gestion des erreurs #}
                {% if errorMessage is defined %}
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>{{ errorMessage }}
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
{% endblock %}
{% block footer %} {% endblock %}