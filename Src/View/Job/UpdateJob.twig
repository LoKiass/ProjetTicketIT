{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Modification Jobs{% endblock %}

{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}

{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-shield-check me-2"></i>Modification Jobs
                    </h1>
                    <p class="text-muted small mb-0">Veuillez fournir toutes les informations ci-dessous</p>
                </div>

                <form method="post">

                    {# Partie projet associé #}
                    <div class="row mb-3 align-items-center">
                        <label for="Fk_Project" class="col-sm-3 col-form-label fw-medium">Projet Associer</label>
                        <div class="col-sm-9">
                            <input type="text" name="Fk_Project" id="Fk_Project" class="form-control"
                                   value="{{ JobEntity.getFk_project() }}" required>
                        </div>
                    </div>

                    {# Partie titre #}
                    <div class="row mb-3 align-items-center">
                        <label for="Titre" class="col-sm-3 col-form-label fw-medium">Titre</label>
                        <div class="col-sm-9">
                            <input type="text" name="Titre" id="Titre" class="form-control"
                                   value="{{ JobEntity.getTitre() }}" required>
                        </div>
                    </div>

                    {# Partie description #}
                    <div class="row mb-3 align-items-center">
                        <label for="Dscr" class="col-sm-3 col-form-label fw-medium">Description</label>
                        <div class="col-sm-9">
                            <input type="text" name="Dscr" id="Dscr" class="form-control"
                                   value="{{ JobEntity.getDscr() }}" required>
                        </div>
                    </div>

                    {# Partie statut #}
                    <div class="row mb-3 align-items-center">
                        <label for="Status" class="col-sm-3 col-form-label fw-medium">Terminé</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch">
                                <input type="checkbox"
                                       name="Status"
                                       id="Status"
                                       class="form-check-input"
                                        {{ JobEntity.getStatus() == 'Terminer' ? 'checked' : '' }}>
                            </div>
                        </div>
                    </div>

                    {# Partie priorité #}
                    <div class="row mb-3 align-items-center">
                        <label for="Prior" class="col-sm-3 col-form-label fw-medium">Priorité</label>
                        <div class="col-sm-9">
                            <input type="text" name="Prior" id="Prior" class="form-control"
                                   value="{{ JobEntity.getPrior() }}" required>
                        </div>
                    </div>

                    {# Partie date début #}
                    <div class="row mb-3 align-items-center">
                        <label for="Dstart" class="col-sm-3 col-form-label fw-medium">Date début</label>
                        <div class="col-sm-9">
                            <input type="date" name="Dstart" id="Dstart" class="form-control"
                                   value="{{ JobEntity.getDstart() }}" required>
                        </div>
                    </div>

                    {# Partie date échéance #}
                    <div class="row mb-3 align-items-center">
                        <label for="Dech" class="col-sm-3 col-form-label fw-medium">Date échéance</label>
                        <div class="col-sm-9">
                            <input type="date" name="Dech" id="Dech" class="form-control"
                                   value="{{ JobEntity.getDech() }}" required>
                        </div>
                    </div>

                    {# Partie date clôture #}
                    <div class="row mb-3 align-items-center">
                        <label for="DClotEst" class="col-sm-3 col-form-label fw-medium">Date clôture</label>
                        <div class="col-sm-9">
                            <input type="date" name="DClotEst" id="DClotEst" class="form-control"
                                   value="{{ JobEntity.getDclot() }}" required>
                        </div>
                    </div>
                    {# Listing des techniciens #}
                    <div class="border rounded-3 overflow-hidden">
                        <table class="table table-hover mb-0">
                            <thead>
                            <tr>
                                <th>Technicien</th>
                                <th></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for tech in TabTech %}
                                <tr>
                                    <td>
                                        <div class="form-check mb-0">
                                            <input class="form-check-input" type="checkbox" name="tech[]" value="{{ tech.getPk() }}" id="t_{{ tech.getPk() }}"
                                                    {% set isChecked = false %}
                                                    {% for jobsTech in JobEntity.getTech() %}
                                                        {% if jobsTech.getPk() == tech.getPk() %}
                                                            {% set isChecked = true %}
                                                        {% endif %}
                                                    {% endfor %}
                                                    {{ isChecked ? 'checked' : '' }}
                                            >
                                            <label class="form-check-label" for="t_{{ tech.getPk() }}">
                                                {{ tech.getNom() }}
                                            </label>
                                        </div>
                                    </td>
                                    <td></td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="2" class="text-center text-muted">Aucun technicien disponible</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {# Partie actions formulaire #}
                    <div class="row mb-3 p-3">
                        <div class="col-12 text-center d-flex justify-content-center gap-2">
                            <button class="btn btn-dark px-4" type="submit">Envoyer</button>
                            <a class="btn btn-dark px-4" href="getJob">Retour</a>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <script src="/DISEUMAT/public/js/checkDate.js"></script>
{% endblock %}