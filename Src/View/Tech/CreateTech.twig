{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Création technicien{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-shield-check me-2"></i>Création d'un techniciens
                    </h1>
                    <p class="text-muted small mb-0">Veuillez fournir toutes les informations ci-dessous</p>
                </div>

                <div class="mt-4 text-center">
                    {% if errorMessage is defined and error %}
                        <p class="text-danger">ERREUR : {{ error }}</p>
                    {% elseif success is defined and success %}
                        <p class="text-success text-center bg-light p-1">Technicien crée avec succès</p>
                    {% endif %}
                </div>

                <form method="post">
                    <div class="row mb-3 align-items-center">
                        <label for="Nom" class="col-sm-3 col-form-label fw-medium">Nom</label>
                        <div class="col-sm-9">
                            <input type="text" name="Nom" id="Nom" class="form-control" required>
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label for="Pren" class="col-sm-3 col-form-label fw-medium">Prenom</label>
                        <div class="col-sm-9">
                            <input type="text" name="Pren" id="Pren" class="form-control" required>
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label for="Email" class="col-sm-3 col-form-label fw-medium">Email</label>
                        <div class="col-sm-9">
                            <input type="email" name="Email" id="Email" class="form-control" required>
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 col-form-label fw-medium">Fonctions</label>
                        <div class="col-sm-9">
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="outside"> {# Permet de cocher plusieurs cases sans fermer le menu #}
                                    Choisir les fonctions...
                                </button>
                                <ul class="dropdown-menu p-3 w-100">
                                    {% for fonction in TabFonction %}
                                        <li>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="fonctions[]" value="{{ fonction.getPk() }}" id="f_{{ fonction.getPk() }}">
                                                <label class="form-check-label w-100" for="f_{{ fonction.getPk() }}">
                                                    {{ fonction.getDescr() }}
                                                </label>
                                            </div>
                                        </li>
                                    {% else %}
                                        <li class="text-muted small ps-2">Aucune fonction disponible</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 text-center d-flex justify-content-center gap-2">
                            <button class="btn btn-dark px-4" type="submit">Envoyer</button>
                            <a class="btn btn-dark px-4" href="getTech">Retour</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

{% endblock %}