{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Modification utilisateur{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-key me-2"></i>Modification du mot de passe utilisateur
                    </h1>
                    <p class="text-muted small mb-0">Veuillez fournir toutes les informations ci-dessous</p>
                </div>

                <form method="post">
                    <div class="row mb-3 align-items-center">
                        <label for="Login" class="col-sm-4 col-form-label fw-medium">Login</label>
                        <div class="col-sm-8">
                            <input type="text" name="Login" id="Login" class="form-control bg-light"
                                   value="{{ UserEntity.getLogin() }}" readonly>
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label for="oldPswd" class="col-sm-4 col-form-label fw-medium">Ancien mot de passe</label>
                        <div class="col-sm-8">
                            <input type="password" name="oldPswd" id="oldPswd" class="form-control">
                        </div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <label for="newPswd" class="col-sm-4 col-form-label fw-medium">Nouveau mot de passe</label>
                        <div class="col-sm-8">
                            <input type="password" name="newPswd" id="newPswd" class="form-control">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 text-center d-flex justify-content-center gap-2">
                            <button class="btn btn-dark px-4" type="submit">Envoyer</button>
                            <a class="btn btn-dark px-4" href="getUser">Retour</a>
                        </div>
                    </div>

                    {% if errorMessage is defined %}
                        <div class="mt-3 text-center">
                            <p class="text-danger">{{ errorMessage }}</p>
                        </div>
                    {% endif %}
                </form>

            </div>
        </div>
    </div>
{% endblock %}