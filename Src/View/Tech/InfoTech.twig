{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Information téchnicien{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-person-badge me-2"></i>Information du technicien
                    </h1>
                    <p class="text-muted small mb-0">Détails du compte technicien</p>
                </div>

                {# Gestion erreur #}
                {% if errorMessage is defined and error %}
                    <p class="alert alert-danger">ERREUR : {{ error }}</p>
                {% endif %}

                {# Partie nom #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Nom</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ TechEntity.getNom }}</p>
                    </div>
                </div>

                {# Partie prénom #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Prénom</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ TechEntity.getPrenom }}</p>
                    </div>
                </div>

                {# Partie e-mail #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Email</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ TechEntity.getEmail }}</p>
                    </div>
                </div>

                {# Partie Status #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Statut</span>
                    <div class="col-sm-9">
                        {% if TechEntity.getActif %}
                            <span class="badge bg-success">Actif</span>
                        {% else %}
                            <span class="badge bg-secondary">Inactif</span>
                        {% endif %}
                    </div>
                </div>

                {# Listing des fonctions #}
                <div class="row mb-3">
                    <div class="col-12">
                        <button class="btn btn-outline-primary w-100 d-flex justify-content-between align-items-center"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#fonctionsCollapse"
                                aria-expanded="false"
                                aria-controls="fonctionsCollapse">
                            <span><i class="bi bi-gear me-2"></i>Fonctions</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>

                        <div class="collapse mt-2" id="fonctionsCollapse">
                            <div class="d-flex flex-wrap gap-2 pt-2 px-2">
                                {% for fonction in TechEntity.getFonctions %}
                                    <span class="bg-primary text-white px-2 py-1 rounded-pill">{{ fonction.getDescr() }}</span>
                                {% else %}
                                    <p class="text-muted small fst-italic mb-0">Aucune fonction assignée</p>
                                {% endfor %}
                            </div>
                        </div>

                    </div>
                </div>

                {# Partie action formulaire #}
                <div class="row">
                    <div class="col-12 text-center">
                        <a class="btn btn-dark px-4" href="getTech">Retour</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}