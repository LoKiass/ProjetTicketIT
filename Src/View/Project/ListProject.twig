{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Liste technicien{% endblock %}

{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}

{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100 mx-3" style="border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-people me-2"></i>Liste des Project
                    </h1>
                    <p class="text-muted small mb-0">Liste de tous les projet enregistrés</p>
                </div>

                {# Gestion des erreurs #}
                {% if errorMessage is defined and errorMessage %}
                    <div class="alert alert-danger">{{ errorMessage }}</div>
                {% endif %}
                {% if successMessage is defined and successMessage != "" %}
                    <div class="alert alert-success">{{ successMessage }}</div>
                {% endif %}
                {% if TabProject is empty %}
                    <div class="alert alert-danger">Aucun projet encore enregistré</div>
                {% endif %}

                {# Tableau des projets #}
                {% if TabProject is not null %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="table-light">
                            <tr>
                                <th class="text-uppercase text-muted fw-semibold text-nowrap">Identifiant</th>
                                <th class="text-uppercase text-muted fw-semibold text-nowrap">Description</th>
                                <th class="text-uppercase text-muted fw-semibold text-nowrap">Date de début</th>
                                <th class="text-uppercase text-muted fw-semibold text-nowrap">Date de clôture</th>
                                <th class="text-uppercase text-muted fw-semibold text-nowrap">Budget</th>
                                <th class="text-uppercase text-muted fw-semibold text-nowrap">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for project in TabProject %}
                                <tr>
                                    <td class="fw-semibold text-nowrap">{{ project.getIdent() }}</td>
                                    <td class="fw-semibold text-nowrap">{{ project.getDescr() }}</td>
                                    <td class="fw-semibold text-nowrap">{{ project.getDstart() }}</td>
                                    <td class="fw-semibold text-nowrap">{{ project.getDClotEst() }}</td>
                                    <td class="fw-semibold text-nowrap">{{ project.getBudget() }}</td>

                                    {# Actions disponibles #}
                                    <td class="text-nowrap">
                                        <a href="updateProject?Pk={{ project.getPk() }}" class="btn btn-sm btn-outline-primary me-1">
                                            Modification
                                        </a>
                                        <a href="getProject?Pk={{ project.getPk() }}" class="btn btn-sm btn-outline-secondary me-1">
                                            Information
                                        </a>
                                        <a href="deleteProject?Pk={{ project.getPk }}" class="btn btn-sm btn-outline-danger">
                                            Suppresions
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
                <div class="container d-flex justify-content-center align-items-center p-5">
                    <a href="createProject" class="btn btn-primary">Ajouter un projet</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}