{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Création technicien{% endblock %}

{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}

{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-shield-check me-2"></i>Création d'un jobs
                    </h1>
                    <p class="text-muted small mb-0">Veuillez fournir toutes les informations ci-dessous</p>
                </div>

                {# Gestion des erreurs #}
                {% if errorMessage is defined and errorMessage %}
                    <div class="mt-4 text-center">
                        <p class="alert alert-danger">ERREUR : {{ errorMessage }}</p>
                    </div>
                {% elseif success is defined and success == true %}
                    <div class="mt-4 text-center">
                        <p class="alert alert-success">Jobs crée avec succès</p>
                    </div>
                {% endif %}

                <form method="post">
                    {# Partie projet associé #}
                    <div class="row mb-3 align-items-center">
                        <label for="Fk_Project" class="col-sm-3 col-form-label fw-medium">Projet associer</label>
                        <div class="col-sm-9">
                            {% if PkProject is defined and PkProject is not null %}
                                <input READONLY type="text" name="Fk_Project" id="Fk_Project" class="form-control" required value="{{ PkProject }}">
                            {% else %}
                                <input type="text" name="Fk_Project" id="Fk_Project" class="form-control" required>
                            {% endif %}
                        </div>
                    </div>

                    {# Partie titre #}
                    <div class="row mb-3 align-items-center">
                        <label for="Titre" class="col-sm-3 col-form-label fw-medium">Titre</label>
                        <div class="col-sm-9">
                            <input type="text" name="Titre" id="Titre" class="form-control" required>
                        </div>
                    </div>

                    {# Partie description #}
                    <div class="row mb-3 align-items-center">
                        <label for="Dscr" class="col-sm-3 col-form-label fw-medium">Description</label>
                        <div class="col-sm-9">
                            <input type="text" name="Dscr" id="Dscr" class="form-control" required>
                        </div>
                    </div>

                    {# Partie statut #}
                    <div class="row mb-3 align-items-center">
                        <label for="Status" class="col-sm-3 col-form-label fw-medium">Status</label>
                        <div class="col-sm-9">
                            <input readonly type="text" name="Status" id="Status" class="form-control" required value="En cours">
                        </div>
                    </div>

                    {# Partie priorité #}
                    <div class="row mb-3 align-items-center">
                        <label for="Prior" class="col-sm-3 col-form-label fw-medium">Priorité</label>
                        <div class="col-sm-9">
                            <input type="text" name="Prior" id="Prior" class="form-control" required>
                        </div>
                    </div>

                    {# Partie date début #}
                    <div class="row mb-3 align-items-center">
                        <label for="Dstart" class="col-sm-3 col-form-label fw-medium">Date début</label>
                        <div class="col-sm-9">
                            <input type="date" name="Dstart" id="Dstart" class="form-control" required>
                        </div>
                    </div>

                    {# Partie date échéance #}
                    <div class="row mb-3 align-items-center">
                        <label for="Dech" class="col-sm-3 col-form-label fw-medium">Date échéance</label>
                        <div class="col-sm-9">
                            <input type="date" name="Dech" id="Dech" class="form-control" required>
                        </div>
                    </div>

                    {# Partie date clôture #}
                    <div class="row mb-3 align-items-center">
                        <label for="DClotEst" class="col-sm-3 col-form-label fw-medium">Date clôture</label>
                        <div class="col-sm-9">
                            <input type="date" name="DClotEst" id="DClotEst" class="form-control" required>
                        </div>
                    </div>

                    {# Listing des techniciens #}
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 col-form-label fw-medium">Techs</label>
                        <div class="col-sm-9">
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="outside">
                                    Choisir les téchniciens
                                </button>
                                <ul class="dropdown-menu p-3 w-100">
                                    {% for Techs in TabTech %}
                                        <li>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox"
                                                       name="Tech[]"
                                                       value="{{ Techs.getPk() }}"
                                                       id="f_{{ Techs.getPk() }}">
                                                <label class="form-check-label w-100" for="f_{{ Techs.getPk() }}">
                                                    {{ Techs.getNom() }}
                                                </label>
                                            </div>
                                        </li>
                                    {% else %}
                                        <li class="text-muted small ps-2">Aucune Techs disponible</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                    </div>

                    {# Partie actions formulaire #}
                    <div class="row mb-3">
                        <div class="col-12 text-center d-flex justify-content-center gap-2">
                            <button class="btn btn-dark px-4" type="submit">Envoyer</button>
                            <a class="btn btn-dark px-4" href="getJob">Retour</a>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <script src="/DISEUMAT/public/js/checkDate.js"></script>
{% endblock %}