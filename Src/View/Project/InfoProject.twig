{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Information projet{% endblock %}

{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}

{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-person-badge me-2"></i>Information du projet
                    </h1>
                    <p class="text-muted small mb-0">Détails du projet</p>
                </div>

                {% if errorMessage is defined %}
                    <div class="mt-4 text-center">
                        <p class="text-danger">{{ errorMessage }}</p>
                    </div>
                {% endif %}

                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Identifiant</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ ProjectEntity.getIdent() }}</p>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Description</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ ProjectEntity.getDescr() }}</p>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Date de début</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ ProjectEntity.getDstart() }}</p>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Date de clôture</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ ProjectEntity.getDClotEst() }}</p>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Budget</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ ProjectEntity.getBudget() }}</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-12">

                        <button class="btn btn-outline-primary w-100 d-flex justify-content-between align-items-center"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#jobsCollapse"
                                aria-expanded="false"
                                aria-controls="jobsCollapse">
                            <span><i class="bi bi-list-task me-2"></i>Jobs ({{ JobsList|length }})</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>

                        <div class="collapse mt-2" id="jobsCollapse">
                            <table class="table table-striped table-hover">
                                <thead>
                                <tr>
                                    <th>Jobs</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for jobs in JobsList %}
                                    <tr>
                                        <td>{{ jobs.getTitre() }}</td>
                                        <td>{{ jobs.getStatus() }}</td>
                                        <td>
                                            <a href="getJob?Pk={{ jobs.getPk() }}" class="btn btn-sm btn-outline-info">
                                                Informations
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="3" class="text-center text-muted">Aucun job</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>


                <div class="row">
                    <div class="col-12 text-center">
                        <a class="btn btn-outline-success px-4" href="getProject">Retour</a>
                        <a class="btn btn-outline-primary px-4" href="updateProject?Pk={{ ProjectEntity.getPk() }}">Modifier</a>
                        <a class="btn btn-outline-danger px-4" href="deleteProject?Pk={{ ProjectEntity.getPk() }}">Supprimer</a>
                        <a class="btn btn-outline-info px-4" href="createJob?Pk={{ ProjectEntity.getPk() }}">Ajouter un job</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}