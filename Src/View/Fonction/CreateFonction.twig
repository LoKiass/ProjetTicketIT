{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Création fonction{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-shield-check me-2"></i>Création d'une fonction
                    </h1>
                    <p class="text-muted small mb-0">Veuillez fournir toutes les informations ci-dessous</p>
                </div>
                <div class="mt-4 text-center">
                    {% if error is defined and error %}
                        <p class="text-danger">ERREUR : {{ error }}</p>
                    {% elseif success is defined and success %}
                        <p class="alert alert-success">Fonction crée avec succès</p>
                    {% endif %}
                </div>
                <form method="post">
                    <div class="row mb-3 align-items-center">
                        <label for="Descr" class="col-sm-3 col-form-label fw-medium">Description</label>
                        <div class="col-sm-9">
                            <input type="text" name="Descr" id="Descr" class="form-control" required>
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label for="Niveau" class="col-sm-3 col-form-label fw-medium">Niveau</label>
                        <div class="col-sm-9">
                            <input type="text" name="Niveau" id="Niveau" class="form-control" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 text-center d-flex justify-content-center gap-2">
                            <button class="btn btn-dark px-4" type="submit">Envoyer</button>
                            <a class="btn btn-dark px-4" href="getFonction ">Retour</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

{% endblock %}