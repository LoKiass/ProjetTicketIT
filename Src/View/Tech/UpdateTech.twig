{% extends 'baseTemplate.twig' %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-shield-check me-2"></i>Création utilisateurs
                    </h1>
                    <p class="text-muted small mb-0">Veuillez fournir toutes les informations ci-dessous</p>
                </div>

                <form method="post">
                    <div class="row mb-3 align-items-center">
                        <label for="Nom" class="col-sm-3 col-form-label fw-medium">Nom</label>
                        <div class="col-sm-9">
                            <input type="text" name="Nom" id="Nom" value="{{ TechEntity.getNom() }}">
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label for="Pren" class="col-sm-3 col-form-label fw-medium">Prenom</label>
                        <div class="col-sm-9">
                            <input type="text" name="Pren" id="Pren" value="{{ TechEntity.getPrenom() }}">
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label for="Email" class="col-sm-3 col-form-label fw-medium">Email</label>
                        <div class="col-sm-9">
                            <input type="text" name="Email" id="Email" value="{{ TechEntity.getEmail() }}">
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-9 offset-sm-3">
                            <div class="form-check">
                                <label for="Actif"> Actif
                                    <input class="form-check-input" type="checkbox" name="Actif" id="Actif" value="1" {{ TechEntity.getActif() ? 'checked' : '' }}>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 text-center">
                            <button class="btn btn-dark px-4" type="submit">Envoyer</button>
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        {% if error is defined and error %}
                            <p class="text-danger">ERREUR : {{ error }}</p>
                        {% elseif success is defined and success %}
                            <p class="text-success">TECHNICIEN CRÉÉ AVEC SUCCÈS</p>
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>
    </div>

{% endblock %}