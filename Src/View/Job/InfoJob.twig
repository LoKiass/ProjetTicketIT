{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Information jobs{% endblock %}

{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}

{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-person-badge me-2"></i>Information du jobs
                    </h1>
                    <p class="text-muted small mb-0">Détails du jobs</p>
                </div>

                {# Gestion erreur #}
                {% if errorMessage is defined %}
                    <div class="mt-4 text-center">
                        <p class="text-danger">{{ errorMessage }}</p>
                    </div>
                {% endif %}

                {# Partie projet associé #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Projet associer</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ nameOfProject }}</p>
                    </div>
                </div>

                {# Partie titre #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Titre</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ JobEntity.getTitre() }}</p>
                    </div>
                </div>

                {# Partie statut #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Status</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ JobEntity.getStatus() }}</p>
                    </div>
                </div>

                {# Partie priorité #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Priorité</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ JobEntity.getPrior() }}</p>
                    </div>
                </div>

                {# Partie date début #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">DStart</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ JobEntity.getDstart() }}</p>
                    </div>
                </div>

                {# Partie date échéance #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Date écheance</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ JobEntity.getDech() }}</p>
                    </div>
                </div>

                {# Partie date clôture #}
                <div class="row mb-3 align-items-center">
                    <span class="col-sm-3 col-form-label fw-medium">Date cloture</span>
                    <div class="col-sm-9">
                        <p class="form-control-plaintext">{{ JobEntity.getDclot() }}</p>
                    </div>
                </div>

                {# Listing des techniciens attitrés #}
                <div class="row mb-3">
                    <div class="col-12">

                        <button class="btn btn-outline-primary w-100 d-flex justify-content-between align-items-center"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#techCollapse"
                                aria-expanded="false"
                                aria-controls="techCollapse">
                            <span><i class="bi bi-people me-2"></i>Techniciens attitrés ({{ JobEntity.getTech()|length }})</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>

                        <div class="collapse mt-2" id="techCollapse">
                            <table class="table table-hover">
                                <thead>
                                <tr>
                                    <th>Nom</th>
                                    <th></th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for tech in JobEntity.getTech %}
                                    <tr>
                                        <td>{{ tech.getNom() }}</td>
                                        <td>
                                            <a href="getTech?Pk={{ tech.getPk() }}" class="btn btn-sm btn-outline-info">
                                                Informations
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="2" class="text-center text-muted">Aucun technicien attitré</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

                {# Partie actions formulaire #}
                <div class="row">
                    <div class="col-12 text-center">
                        <a class="btn btn-outline-success px-4" href="getJob">Retour</a>
                        <a class="btn btn-outline-danger px-4" href="deleteJob?Pk={{ JobEntity.getPk() }}">Supprimer</a>
                        <a class="btn btn-outline-info px-4" href="updateJob?Pk={{ JobEntity.getPk() }}">Modifier</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}