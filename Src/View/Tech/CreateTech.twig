{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Création technicien{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-shield-check me-2"></i>Création d'un techniciens
                    </h1>
                    <p class="text-muted small mb-0">Veuillez fournir toutes les informations ci-dessous</p>
                </div>

                {# Gestion erreur #}
                <div class="mt-4 text-center">
                    {% if errorMessage is defined and error %}
                        <p class="alert alert-danger">ERREUR : {{ error }}</p>
                    {% elseif success is defined and success %}
                        <p class="alert alert-success">Technicien crée avec succès</p>
                    {% endif %}
                </div>

                {# Formulaire #}
                <form method="post">
                    {# Partie nom #}
                    <div class="row mb-3 align-items-center">
                        <label for="Nom" class="col-sm-3 col-form-label fw-medium">Nom</label>
                        <div class="col-sm-9">
                            <input type="text" name="Nom" id="Nom" class="form-control" required>
                        </div>
                    </div>

                    {# Partie prenom #}
                    <div class="row mb-3 align-items-center">
                        <label for="Pren" class="col-sm-3 col-form-label fw-medium">Prenom</label>
                        <div class="col-sm-9">
                            <input type="text" name="Pren" id="Pren" class="form-control" required>
                        </div>
                    </div>

                    {# Partie e-mail #}
                    <div class="row mb-3 align-items-center">
                        <label for="Email" class="col-sm-3 col-form-label fw-medium">Email</label>
                        <div class="col-sm-9">
                            <input type="email" name="Email" id="Email" class="form-control" required>
                        </div>
                    </div>

                    {# Partie actif #}
                    <div class="row mb-3 align-items-center">
                        <label for="Actif" class="col-sm-3 col-form-label fw-medium">Actif</label>
                        <div class="col-sm-9">
                            <div class="form-switch">
                                <input class="form-check-input" type="checkbox" name="Actif" id="Actif" value="1">
                            </div>
                        </div>
                    </div>

                    {# Liste des fonctions #}
                    <div class="row mb-3 align-items-center">
                        <table class="table table-striped table-hover">
                            <tr>
                                <th>Fonctions</th>
                                <th></th>
                                {% for fonction in TabFonction %}
                                </tr>
                                    <th>{{ fonction.getDescr() }}</th>
                                    <th><input type="checkbox" name="fonctions[]" value="{{ fonction.getPk() }}"></th>
                            {% endfor %}
                        </table>
                    </div>

                    {# Bouton action #}
                    <div class="row">
                        <div class="col-12 text-center d-flex justify-content-center gap-2">
                            <button class="btn btn-outline-success px-4" type="submit">Envoyer</button>
                            <a class="btn btn-outline-warning px-4" href="getTech">Retour</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

{% endblock %}