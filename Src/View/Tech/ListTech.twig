{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Liste technicien{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}

{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 800px; border-radius: 12px;">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-people me-2"></i>Liste des techniciens
                    </h1>
                    <p class="text-muted small mb-0">Liste de tous les techniciens enregistrés</p>
                </div>

                {# Gestion Erreur#}
                {% if errorMessage is defined and errorMessage != null %}
                    <div class="alert alert-danger">{{ errorMessage }}</div>
                {% endif %}
                {% if successMessage is defined and successMessage != null %}
                    <div class="alert alert-success">{{ successMessage }}</div>
                {% endif %}
                {% if TabTech is empty %}
                    <div class="alert alert-danger">Aucun téchniciens encore enregistré </div>
                {% endif %}


                {% if TabTech is not null %}
                    <div class="table-responsive">
                        {# Tableau techniciens#}
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th class="text-uppercase small text-muted fw-semibold">Nom</th>
                                <th class="text-uppercase small text-muted fw-semibold">Prénom</th>
                                <th class="text-uppercase small text-muted fw-semibold">Email</th>
                                <th class="text-uppercase small text-muted fw-semibold">Statut</th>
                                <th class="text-uppercase small text-muted fw-semibold">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {# Informations techniciens #}
                            {% for tech in TabTech %}
                                <tr>
                                    <td class="fw-semibold">{{ tech.getNom }}</td>
                                    <td>{{ tech.getPrenom }}</td>
                                    <td class="text-muted">{{ tech.getEmail }}</td>
                                    <td>
                                        {% if tech.getActif %}
                                            <span class="badge bg-success">Actif</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Inactif</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-nowrap">
                                        <a href="updateTech?Pk={{ tech.getPk }}" class="btn btn-sm btn-outline-primary me-1">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                        <a href="getTech?Pk={{ tech.getPk }}" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-info-circle"></i> Infos
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
                <div class="container d-flex justify-content-center align-items-center p-5">
                    <a href="createTech" class="btn btn-primary">Ajouter un technicien</a>
                </div>

            </div>
        </div>
    </div>
{% endblock %}