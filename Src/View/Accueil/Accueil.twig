{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Accueil{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock%}
{% block content %}
    <div class="min-vh-45 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 900px; border-radius: 12px;">
            <div class="card-header bg-white border-0">
                <h3 class="fw-bold text-center text-secondary">Bienvenu <span class="text-primary">{{ userLogged.Login }}</span></h3>
            </div>
            <div class="card-body p-4">
                <h5 class="card-title text-center mb-4 fw-bold text-secondary">Tableau des Statistiques</h5>
                <div class="row row-cols-1 row-cols-md-3 g-3 text-center">

                    <div class="col">
                        <div class="p-3 bg-white border rounded">
                            <div class="text-muted small fw-medium text-uppercase">Téchniciens totale</div>
                            <div class="fs-3 fw-bold text-dark mt-1">{{ nbrTech }}</div>
                        </div>
                    </div>

                    <div class="col">
                        <div class="p-3 bg-white border rounded">
                            <div class="text-muted small fw-medium text-uppercase">Jobs totale</div>
                            <div class="fs-3 fw-bold mt-1">{{ nbrJobs }}</div>
                        </div>
                    </div>

                    <div class="col">
                        <div class="p-3 bg-white border rounded">
                            <div class="text-muted small fw-medium text-uppercase">Projet totale</div>
                            <div class="fs-3 fw-bold mt-1">125</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{# Permet de ne pas afficher le login car afficher en haut de page #}
{% block footer %}{% endblock %}