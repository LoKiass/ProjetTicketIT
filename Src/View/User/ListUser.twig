{% extends 'baseTemplate.twig' %}
{% block pagetitle %}TicketSystem - Liste utilisateur{% endblock %}
{% block navbar %}
    {% include 'Navbar/Navbar.twig' %}
{% endblock %}

{% block content %}
    <div class="min-vh-100 d-flex justify-content-center bg-light py-5">
        <div class="card shadow-sm border-0 w-100" style="max-width: 650px; border-radius: 12px;">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1 class="h4 fw-semibold mb-1">
                        <i class="bi bi-shield-check me-2"></i>Liste des utilisateurs
                    </h1>
                    <p class="text-muted small mb-0">Liste de tous les utilisateurs enregistrés</p>
                </div>

                {% if errorMessage is defined and errorMessage != null %}
                    <div class="alert alert-danger">{{ errorMessage }}</div>
                {% endif %}

                {% if TabUser is defined and TabUser is not empty %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th class="text-uppercase small text-muted fw-semibold">Identifiant</th>
                                <th class="text-uppercase small text-muted fw-semibold">Statut</th>
                                <th class="text-uppercase small text-muted fw-semibold">Actif</th>
                                <th class="text-uppercase small text-muted fw-semibold">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for user in TabUser %}
                                <tr>
                                    <td class="fw-semibold">{{ user.getLogin() }}</td>
                                    <td>
                                <span class="badge bg-primary">
                                    {{ user.getStatut() }}
                                </span>
                                    </td>
                                    <td>
                                        {% if user.getActif %}
                                            <span class="badge bg-success">Actif</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Inactif</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <a href="updateUser?Login={{ user.getLogin() }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}